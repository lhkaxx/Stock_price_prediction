# ============================================================
#  Python 字节码缓存
# ============================================================
# Python 运行时自动生成，与项目无关，且不同 Python 版本间不兼容
__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================================
#  虚拟环境（本地开发用）
# ============================================================
#  conda/pip 安装的依赖体积巨大（torch 就 2GB+），
#  且通过 requirements.txt 即可在任何机器上精确复现，
#  提交到 git 只会拖垮仓库、毫无收益
.venv/
venv/
env/
*.egg-info/
dist/
build/
pip-wheel-metadata/

# ============================================================
#  生成数据（可复现，不应入库）
# ============================================================
#  data/*.npy 和 data/*.npz 由 feature_engineering.py 生成
#  models/*.pt 由 model_lstm.py / model_gru.py 训练产出
#  figures/*.png 由 evaluation.py 生成
#  三者均可通过运行 main.py 完全复现，提交到 git 会造成：
#    1. 仓库膨胀（npy/pt 是二进制大文件）
#    2. 每次重新训练都产生无意义的 diff
#    3. 不同机器/不同次训练结果不同 → 合并冲突
data/*.npy
data/*.npz
models/*.pt
models/*.pkl
models/*.npz
figures/*.png

# ============================================================
#  IDE / 编辑器配置（个人偏好，不应强加给协作者）
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
#  操作系统杂项
# ============================================================
# macOS Finder 自动生成，Windows 用户不需要
.DS_Store
# Windows 缩略图缓存
Thumbs.db
# Linux 目录快照
.directory

# ============================================================
#  Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
#  环境变量 / 密钥（绝不能泄露）
# ============================================================
.env
.env.local
.env.*.local
